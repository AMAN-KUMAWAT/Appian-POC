<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0001efd2-cfb4-8000-9c83-011c48011c48_6989207</versionUuid>
    <rule>
        <name>WS_QRY_ExistingDeployedPackages</name>
        <uuid>_a-0001efd2-cfb4-8000-9c83-011c48011c48_6989081</uuid>
        <description>this rule will be used to check the existing deployed packages</description>
        <parentUuid>1cbdd368-c34e-4520-a8e6-8c346cb905b9</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  or(
    a!isNullOrEmpty(
      ri!SelectedPackageName
    ),
    a!isNullOrEmpty(
      ri!SelectedApplicationName
    )
  ),
  true,
  a!localVariables(
    local!deployedPackageData:#"SYSTEM_SYSRULES_queryRecordType_v4"(
      recordType: #"urn:appian:record-type:v1:7b9ea405-1768-4649-983e-c61ea895fddc",
      filters: #"SYSTEM_SYSRULES_queryLogicalExpression"(
        operator: "AND",
        filters: {
          #"SYSTEM_SYSRULES_queryFilter"(
            field: #"urn:appian:record-field:v1:7b9ea405-1768-4649-983e-c61ea895fddc/b987f78a-50ae-48ce-9f0a-755afb0ae6c9",
            operator: "=",
            value: ri!SelectedApplicationName
          ),
          #"SYSTEM_SYSRULES_queryFilter"(
            field: #"urn:appian:record-field:v1:7b9ea405-1768-4649-983e-c61ea895fddc/cc23ffa8-74fd-4b27-bd6a-c2d66f9a0482",
            operator: "=",
            value: ri!SelectedPackageName
          )
        }
      ),
      pagingInfo: #"SYSTEM_SYSRULES_pagingInfo"(1,1)
    ).data,
    a!isNotNullOrEmpty(
      local!deployedPackageData
    )
  )
)</definition>
        <namedTypedValue>
            <name>SelectedPackageName</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <namedTypedValue>
            <name>SelectedApplicationName</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
