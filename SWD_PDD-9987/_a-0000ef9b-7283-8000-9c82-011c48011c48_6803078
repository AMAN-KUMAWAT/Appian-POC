<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0001efd2-cfb4-8000-9c83-011c48011c48_6994440</versionUuid>
    <rule>
        <name>WS_getObjectPropertyByUUID</name>
        <uuid>_a-0000ef9b-7283-8000-9c82-011c48011c48_6803078</uuid>
        <description>this expression rule is used to get the name and type of the object</description>
        <parentUuid>1cbdd368-c34e-4520-a8e6-8c346cb905b9</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>a!localVariables(
  local!text:getcontentdetailsbyuuid(
    objectUUID: ri!uuid
  ),
  a!map(
    name: a!defaultValue(trim(
      index(
        split(
          index(
            split(local!text, "Name: "),
            2,
            ""
          ),
          ", Id:"
        ),
        1,
        ""
      )
    ),"Unidentified Entity"),

    type: a!defaultValue(trim(
      index(
        split(
          index(
            split(local!text, "Type: "),
            2,
            ""
          ),
          ", Created by:"
        ),
        1,
        ""
      )
    ),"Unidentified Entity")
  )
)</definition>
        <namedTypedValue>
            <name>uuid</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
    <roleMap public="true">
