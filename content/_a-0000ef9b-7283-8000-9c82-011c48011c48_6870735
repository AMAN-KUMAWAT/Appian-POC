    <rule>
        <name>WS_CalculateStockForProduct</name>
        <uuid>_a-0000ef9b-7283-8000-9c82-011c48011c48_6870735</uuid>
        <description></description>
        <parentUuid>1cbdd368-c34e-4520-a8e6-8c346cb905b9</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  a!isNullOrEmpty(ri!productId),
  null,
  a!localVariables(
    local!transactions:#"SYSTEM_SYSRULES_queryRecordType_v4"(
      recordType: #"urn:appian:record-type:v1:d73345d4-10de-411c-a7c1-3d96182741bd",
      fields: #"SYSTEM_SYSRULES_aggregationFields"(
        groupings: {
          #"SYSTEM_SYSRULES_grouping"(
            field: #"urn:appian:record-field:v1:d73345d4-10de-411c-a7c1-3d96182741bd/aaed3aae-4260-4495-b795-fb0ffbc2b783",
            alias: "transactionType"
          )
        },
        measures: {
          #"SYSTEM_SYSRULES_measure"(
            field: #"urn:appian:record-field:v1:d73345d4-10de-411c-a7c1-3d96182741bd/b76ae3c0-43c2-4bf3-89c6-1296863f4339",
            function: "SUM",
            alias: "quantity_sum"
          )
        }
      ),
      filters: #"SYSTEM_SYSRULES_queryLogicalExpression"(
        operator: "AND",
        filters: {
          #"SYSTEM_SYSRULES_queryFilter"(
            field: #"urn:appian:record-field:v1:d73345d4-10de-411c-a7c1-3d96182741bd/73a4b807-8117-4ce4-8c30-f579492c48e6",
            operator: "=",
            value: ri!productId
          )
        },
        ignoreFiltersWithEmptyValues: true
      ),
      pagingInfo: #"SYSTEM_SYSRULES_pagingInfo"(
        startIndex: 1,
        batchSize: 100
      )
    ).data,
    local!totatlIn:a!defaultValue(index(index(local!transactions,wherecontains(
      "IN",
      touniformstring(
        local!transactions.transactionType
      )
    ),0),"quantity_sum",0),0),
    local!totatlOut:a!defaultValue(index(index(local!transactions,wherecontains(
      "OUT",
      touniformstring(
        local!transactions.transactionType
      )
    ),0),"quantity_sum",0),0),
    local!stock:local!totatlIn-local!totatlOut,
    cast(1,local!stock)
  )
)</definition>
        <namedTypedValue>
            <name>productId</name>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
