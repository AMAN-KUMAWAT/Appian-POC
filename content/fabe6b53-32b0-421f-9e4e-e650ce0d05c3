<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0001efd2-cfb4-8000-9c83-011c48011c48_6990116</versionUuid>
    <interface>
        <name>WS_AppianPckagesTest</name>
        <uuid>_a-0001efd2-cfb4-8000-9c83-011c48011c48_6986199</uuid>
        <description>interface to test extraction of packages</description>
        <parentUuid>1cbdd368-c34e-4520-a8e6-8c346cb905b9</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>a!localVariables(
  local!selectedApplication,
  local!getAllPackagesFromApplication: a!refreshVariable(
    value: #"84c6682e-38fa-4d18-bafb-c5e20f3e4389"(
      appUuid: local!selectedApplication
    ).result.body.packages,
    refreshOnVarChange: local!selectedApplication
  ),

  local!selectedPackage,
  local!applicationsNameandUUId:#"SYSTEM_SYSRULES_forEach"(
    items: #"_a-0001efd2-cfb4-8000-9c83-011c48011c48_6986322",
    expression: #"_a-0001efd2-cfb4-8000-9c83-011c48011c48_6986417"(
      contentDetails: getcontentobjectdetailsbyid(
        fv!item
      )
    )
  ),
  local!isPushButtonDisabled:a!refreshVariable(
    value: #"_a-0001efd2-cfb4-8000-9c83-011c48011c48_6989081"(
      SelectedPackageName: ri!SelectedPackageName,
      SelectedApplicationName: ri!SelectedApplicationName
    ),
    refreshOnVarChange: ri!SelectedPackageName
  ),
  {
    #"SYSTEM_SYSRULES_cardLayout"(
      contents: {
        #"SYSTEM_SYSRULES_richTextDisplayField"(
          value: {
            #"SYSTEM_SYSRULES_richTextItem_v1"(
              text: "📦 Export Application Package",
              size: "LARGE",
              style: "STRONG"
            )
          },
          align: "CENTER"
        ),

        #"SYSTEM_SYSRULES_richTextDisplayField"(
          value: {
            #"SYSTEM_SYSRULES_richTextItem_v1"(
              text: "Select an application package and export it as a ZIP file.",
              color: "SECONDARY"
            )
          },
          marginBelow: "STANDARD",
          align: "CENTER"
        ),
        #"SYSTEM_SYSRULES_sectionLayout_v1"(
          label: "Application Selection",
          contents: {
            #"SYSTEM_SYSRULES_dropdownField_v1"(
              labelPosition: "ABOVE",
              placeholder: "--- Select an Application ---",
              choiceLabels: index(
                local!applicationsNameandUUId,
                "name",null
              ),
              choiceValues: index(
                local!applicationsNameandUUId,
                "uuid",null
              ),
              validations: {},
              searchDisplay: "AUTO",
              saveInto: {
                local!selectedApplication,
                a!save(
                  ri!SelectedApplicationName,
                  index(index(
                    local!applicationsNameandUUId,
                    wherecontains(
                      save!value,
                      index(
                        local!applicationsNameandUUId,
                        "uuid",null
                      )
                    ),
                    {}
                  ),"name",{})
                )
                },
              value: local!selectedApplication
            )
            
          }
        ),

        #"SYSTEM_SYSRULES_sectionLayout_v1"(
          label:"Application Packages",
          contents: {
            #"SYSTEM_SYSRULES_dropdownField_v1"(
              labelPosition: "ABOVE",
              placeholder: "--- Select a Package ---",
              value: ri!SelectedPackageUUID,
              saveInto:
                {
                  ri!SelectedPackageUUID,
                  a!save(
                    ri!SelectedPackageName,
                    index(index(
                      local!getAllPackagesFromApplication,
                      wherecontains(
                        save!value,
                        index(
                          local!getAllPackagesFromApplication,
                          "uuid",null
                        )
                      ),
                      {}
                    ),"name",{})
                  )
                  
                  },
              choiceLabels: index(
                local!getAllPackagesFromApplication,
                "name",
                null
              ),
              choiceValues: index(
                local!getAllPackagesFromApplication,
                "uuid",
                null
              ),
              validations: {},
              searchDisplay: "AUTO"
            )
          }
        ),

        if(
          isnull(ri!SelectedPackageUUID),
          {},
          #"SYSTEM_SYSRULES_cardLayout"(
            contents: {
              #"SYSTEM_SYSRULES_richTextDisplayField"(
                value: {
                  #"SYSTEM_SYSRULES_richTextIcon"(
                    icon: if(
                      local!isPushButtonDisabled,
                      "exclamation-circle",
                      "check-circle"
                    ),
                    
                    color: if(
                      local!isPushButtonDisabled,
                      "NEGATIVE",
                      "POSITIVE"
                    )
                  ),
                  if(
                    local!isPushButtonDisabled,
                    " Selected Package Already Pushed",
                    " Package selected and ready for export."
                  )
                }
              )
            },
            marginAbove: "STANDARD",
            style: "SUCCESS",
            decorativeBarColor: if(local!isPushButtonDisabled,"#FF0000","#4169E1"),
            decorativeBarPosition: "START",
            shape: "ROUNDED",
            
            
          )
        )
      },
      marginBelow: "STANDARD",
      style: "STANDARD",
      showBorder: true,
      padding: "MORE",
      shape: "ROUNDED"
    ),

    #"SYSTEM_SYSRULES_ButtonArrayLayout"(
      buttons: {
        #"SYSTEM_SYSRULES_buttonWidget_v1"(
          label: "Cancel",
          value: "CANCEL",
          saveInto: {
            a!save(
              ri!ButtonAction,
              "CANCEL"
            )
          },
          submit: true,
          style: "OUTLINE"
        ),

        #"SYSTEM_SYSRULES_buttonWidget_v1"(
          tooltip: if(
            a!isNullOrEmpty(
              ri!SelectedApplicationName
            ),
            "Please Select an Application",
            if(

              a!isNullOrEmpty(
                ri!SelectedPackageName
              ),
              "Please Select a Package",
              null
            )
          ),
          disabled: local!isPushButtonDisabled,
          label: "PUSH TO GIT",
          value: "EXPORT",
          saveInto: {
            a!save(
              ri!ButtonAction,
              "EXPORT"
            ),
            a!save(
              local!selectedPackage,
              index(
                local!getAllPackagesFromApplication,
              1,
              null)
            )
          },
          submit: true,
          style: "OUTLINE"
        )
      },
      align: "END"
    )
  }
)</definition>
        <namedTypedValue>
            <name>SelectedPackageUUID</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <namedTypedValue>
            <name>ButtonAction</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <namedTypedValue>
            <name>SelectedPackageName</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <namedTypedValue>
            <name>SelectedApplicationName</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <preferredEditor>interface</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
        <isCustom>false</isCustom>
    </interface>
