      #"SYSTEM_SYSRULES_gridLayoutHeaderCell"(label: "Fri"),
      #"SYSTEM_SYSRULES_gridLayoutHeaderCell"(label: "Sat"),
    },
    columnConfigs: {},
    rows: {
      #"SYSTEM_SYSRULES_forEach"(
        items:enumerate(6),
          expression: #"SYSTEM_SYSRULES_gridRowLayout"(
            contents: {
              #"SYSTEM_SYSRULES_richTextDisplayField"(
                value:{
                  #"SYSTEM_SYSRULES_richTextItem_v1"(
