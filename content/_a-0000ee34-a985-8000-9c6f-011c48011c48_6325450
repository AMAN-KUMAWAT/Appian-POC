                      ),
                      "ACCENT",
                      {}
                    ),
                    size: if(
                      and(
                        local!currentMonth=local!iterativeMonth,
                        local!currentYear=local!todayYear,
                        index(
                          local!finalArray,
                          1+(7*fv!index-7),
                          null
